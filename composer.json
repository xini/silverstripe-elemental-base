{
  "name": "fromholdio/silverstripe-elemental-base",
  "type": "silverstripe-vendormodule",
  "description": "Base layer to sit on OOTB elemental providing first-class multi-areas and other enhancements",
  "license": "BSD-3-Clause",
  "keywords": ["silverstripe"],
  "homepage": "https://github.com/fromholdio/silverstripe-elemental-base",
  "support": {
    "issues": "https://github.com/fromholdio/silverstripe-elemental-base/issues"
  },
  "authors": [{
    "name": "Luke Fromhold",
    "homepage": "https://fromhold.io"
  }],
  "require": {
    "dnadesign/silverstripe-elemental": "^6.0.2",
    "fromholdio/silverstripe-checkboxfieldgroup": "^1.2.0",
    "fromholdio/silverstripe-cms-fields-placement": "^1.2.0",
    "lekoala/silverstripe-cms-actions": "^2.0.0"
  },
  "autoload": {
    "psr-4": {
      "Fromholdio\\Elemental\\Base\\": "src/"
    }
  },
  "extra": {
    "expose": [
      "client/dist"
    ],
      "branch-alias": {
          "dev-3.x": "3.0.x-dev"
      }
  },
  "prefer-stable": true,
  "minimum-stability": "dev"
}
